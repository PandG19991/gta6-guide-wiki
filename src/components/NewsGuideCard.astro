---
import { categoryMetaByName, type Guide } from "@data/guides";

interface Props {
  guide: Guide;
}

const { guide } = Astro.props;
const category = categoryMetaByName[guide.category];
---

<article class="content-card news-guide-card">
  <a class="news-card-media" href={`/guides/${guide.slug}/`} aria-label={guide.title}>
    <img src={category.image} alt={`${guide.category} GTA 6 guide artwork`} width="1672" height="941" loading="lazy" decoding="async" />
  </a>
  <div class="card-meta">
    <span class="badge category">{guide.category}</span>
  </div>
  <h3><a href={`/guides/${guide.slug}/`}>{guide.title}</a></h3>
  <p>{guide.deck}</p>
  <div class="card-actions">
    <strong class="meta-label">Updated</strong>
    <p>{guide.updated}</p>
  </div>
</article>
