---
import GuideMedia from "./GuideMedia.astro";
import type { PublicGuide } from "@data/guides";

interface Props {
  guide: PublicGuide;
}

const { guide } = Astro.props;
---

<article class="content-card news-guide-card">
  <a class="news-card-media" href={`/guides/${guide.slug}/`} aria-label={guide.title}>
    <GuideMedia id={guide.primaryMediaId} sizes="(max-width: 720px) 100vw, 33vw" />
  </a>
  <div class="card-meta">
    <span class="badge category">{guide.category}</span>
  </div>
  <h3><a href={`/guides/${guide.slug}/`}>{guide.title}</a></h3>
  <p>{guide.deck}</p>
  <div class="card-actions">
    <strong class="meta-label">Updated</strong>
    <p>{guide.updated}</p>
  </div>
</article>
