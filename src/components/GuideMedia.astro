---
import { Picture } from "astro:assets";
import { mediaById, type MediaId } from "@data/media";

interface Props {
  id: MediaId;
  priority?: boolean;
  sizes?: string;
}

const { id, priority = false, sizes = "(max-width: 768px) 100vw, 680px" } = Astro.props;
const media = mediaById[id];
if (!media || media.rights !== "approved") throw new Error(`Unapproved media: ${id}`);
---

<figure class="guide-media">
  <Picture
    src={media.local}
    alt={media.alt}
    widths={[480, 768, 1280]}
    sizes={sizes}
    formats={["avif", "webp"]}
    loading={priority ? "eager" : "lazy"}
    decoding="async"
    priority={priority}
    data-media-id={media.id}
  />
</figure>

<style>
  .guide-media { margin: 0; }
  .guide-media :global(img) { display: block; width: 100%; height: auto; }
</style>
