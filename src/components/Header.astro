---
import BrandMark from "./BrandMark.astro";
import { navItems, site } from "@data/site";

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="shell nav-shell">
    <a class="brand" href="/" aria-label={`${site.name} home`}>
      <span>{site.name.split(" ")[0]}<br />{site.name.split(" ")[1]}</span>
      <BrandMark />
    </a>
    <nav class="main-nav" aria-label="Primary navigation">
      {navItems.map((item) => (
        <a href={item.href} aria-current={currentPath.startsWith(item.href) ? "page" : undefined}>
          {item.label}
        </a>
      ))}
    </nav>
    <div class="nav-actions" aria-label="Quick links">
      <a class="icon-button" href="/guides/" aria-label="Search guides">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.5-3.5"></path>
        </svg>
      </a>
      <a class="icon-button" href="/editorial-policy/" aria-label="Editorial policy">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 3 4 6v6c0 5 3.5 8 8 9 4.5-1 8-4 8-9V6l-8-3Z"></path>
          <path d="m9 12 2 2 4-5"></path>
        </svg>
      </a>
    </div>
  </div>
</header>

