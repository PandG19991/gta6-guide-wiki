---
import BaseLayout from "@layouts/BaseLayout.astro";
import { site } from "@data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About Leonida Ledger",
  description: "About Leonida Ledger's independent GTA 6 guide, source policy, and update standards.",
  url: `${site.url}/about/`
};
---

  <BaseLayout
  title="About"
  description="About Leonida Ledger, an independent GTA 6 guide site with official sources, corrections, contact details, and a clear privacy policy."
  schema={schema}
>
  <header class="page-header shell">
    <div class="page-kicker">About</div>
    <h1 class="page-title">About Leonida Ledger</h1>
    <p class="page-intro">
      Leonida Ledger is an independent, fan-made GTA 6 guide and database site for players who want quick answers backed by clear sources.
    </p>
  </header>

  <section class="section-tight shell split">
    <article class="panel">
      <h2>Independent Guide</h2>
      <p>
        Leonida Ledger is fan-made and is not affiliated with, endorsed by, or sponsored by Rockstar Games,
        Take-Two Interactive, PlayStation, or Xbox.
      </p>
      <p>We focus on clear GTA 6 answers, practical player decisions, and direct links to official information.</p>
    </article>
    <article class="panel">
      <h2>Corrections And Contact</h2>
      <p>
        Found an error, outdated detail, rights concern, or broken link? Use the <a href="/contact/">contact page</a>.
        See <a href="/sources/">sources and corrections</a> for source priorities and the <a href="/editorial-policy/">editorial policy</a> for rumor and copyright boundaries.
      </p>
      <p>Our current data practices are explained in the <a href="/privacy/">Privacy Policy</a>.</p>
    </article>
  </section>
</BaseLayout>
