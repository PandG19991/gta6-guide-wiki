---
import BaseLayout from "@layouts/BaseLayout.astro";
import { site } from "@data/site";

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About Leonida Ledger",
  description: "About Leonida Ledger's independent GTA 6 guide, source policy, and update standards.",
  url: `${site.url}/about/`
};
---

<BaseLayout
  title="About"
  description="About Leonida Ledger, an independent GTA 6 guide site built around official sources, evidence labels, and launch-week verification."
  schema={schema}
>
  <header class="page-header shell">
    <div class="page-kicker">About</div>
    <h1 class="page-title">About Leonida Ledger</h1>
    <p class="page-intro">
      Leonida Ledger is an independent, fan-made GTA 6 guide and database site for players who want quick answers with visible source boundaries.
    </p>
  </header>

  <section class="section-tight shell split">
    <article class="panel">
      <h2>What We Publish</h2>
      <ul>
        <li>Official release, platform, preorder, location, and character facts with source links.</li>
        <li>Observed trailer/media notes only when they can be stated without speculative extrapolation.</li>
        <li>Launch-week testing templates for missions, cheats, vehicles, map markers, and money methods.</li>
      </ul>
    </article>
    <article class="panel">
      <h2>What We Do Not Publish</h2>
      <ul>
        <li>No leaked footage, leaked maps, copied guide text, or rehosted official media packs.</li>
        <li>No fake cheat codes, fake PC downloads, generator bait, or untested walkthrough claims.</li>
        <li>No affiliation claim with Rockstar Games, Take-Two Interactive, PlayStation, or Xbox.</li>
      </ul>
    </article>
  </section>

  <section class="section-tight shell">
    <div class="panel">
      <h2>How Updates Work</h2>
      <p>
        Pre-launch pages use official sources, policy sources, and explicit confidence labels. After launch, guide updates should record platform, date, method, result, spoiler level, and repeatability before they become walkthrough advice.
      </p>
      <p>
        Start with the <a href="/sources/">source ledger</a>, <a href="/editorial-policy/">editorial policy</a>, or <a href="/testing-protocol/">testing protocol</a>.
      </p>
    </div>
  </section>
</BaseLayout>
