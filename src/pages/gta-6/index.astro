---
import Gta6Rail from "@components/Gta6Rail.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import GuideMedia from "@components/GuideMedia.astro";
import { gta6DatabaseCards, gta6FeatureSections, gta6HubStats } from "@data/gta6";
import { publicGuides } from "@data/guides";
import { publicUpdates } from "@data/updates";
import { site } from "@data/site";

const startHereSlugs = [
  "gta-6-release-date-countdown-preload",
  "gta-6-pre-order-standard-vs-ultimate",
  "gta-6-map-leonida-regions-locations",
  "gta-6-characters-official-cast"
];
const startHere = publicGuides.filter((guide) => startHereSlugs.includes(guide.slug));

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "GTA 6 Hub",
    description: "GTA 6 release facts, confirmed features, vehicles, characters, locations, and editions in one hub.",
    url: `${site.url}/gta-6/`
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url },
      { "@type": "ListItem", position: 2, name: "GTA 6", item: `${site.url}/gta-6/` }
    ]
  }
];
---

<BaseLayout
  title="GTA 6 Guide And Database"
  description="GTA 6 release facts, confirmed features, vehicles, characters, locations, and editions in one hub."
  schema={schema}
>
  <header class="page-header shell hub-header">
    <div>
      <h1 class="page-title">GTA 6 Guide And Database</h1>
      <p class="page-intro">
        Start with the confirmed release details, then browse features, vehicles, characters, locations, and editions.
      </p>
    </div>
    <div class="hub-actions">
      <a class="button" href="/gta-6/features/">Confirmed Features</a>
      <a class="button secondary" href="/gta-6/database/">Open Database</a>
    </div>
  </header>

  <Gta6Rail />

  <section class="section-tight shell">
    <div class="section-heading">
      <h2>Start Here</h2>
      <p>Make the main pre-launch decisions: when GTA 6 releases, which edition fits, and what Rockstar has confirmed about Leonida and its cast.</p>
    </div>
    <div class="content-grid">
      {startHere.map((guide) => (
        <article class="content-card">
          {guide.primaryMediaId && (
            <a class="news-card-media" href={`/guides/${guide.slug}/`} aria-label={guide.title}>
              <GuideMedia id={guide.primaryMediaId} sizes="(max-width: 720px) 100vw, 25vw" />
            </a>
          )}
          <h3><a href={`/guides/${guide.slug}/`}>{guide.title}</a></h3>
          <p>{guide.bullets[0]}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-tight shell">
    <div class="section-heading">
      <h2>Meaningful Changes</h2>
      <p>Official changes that affect a current player decision or guide answer.</p>
    </div>
    <div class="feature-grid">
      {publicUpdates.slice(0, 3).map((update) => (
        <article class="content-card compact-card">
          <p class="page-kicker"><time datetime={update.date}>{update.date}</time> - {update.source}</p>
          <h3>{update.title}</h3>
          <p><a href={update.affectedRoutes[0]}>See the affected guide</a></p>
        </article>
      ))}
    </div>
    <div class="section-actions">
      <a class="button secondary" href="/updates/">View all meaningful changes</a>
    </div>
  </section>

  <section class="section-tight shell">
    <div class="stats-grid">
      {gta6HubStats.map((stat) => (
        <article class="stat-card">
          <strong class="meta-label">{stat.label}</strong>
          <p>{stat.value}</p>
          <span>{stat.detail}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section-tight shell">
    <div class="section-heading">
      <h2>Confirmed Features</h2>
      <p>See confirmed release, setting, character, and vehicle information with links to detailed guides.</p>
    </div>
    <div class="feature-grid">
      {gta6FeatureSections.slice(0, 4).map((section) => (
        <article class="content-card compact-card">
          <h3><a href={section.href}>{section.title}</a></h3>
          <p>{section.points[0]}</p>
        </article>
      ))}
    </div>
    <div class="section-actions">
      <a class="button secondary" href="/gta-6/features/">View all confirmed features</a>
    </div>
  </section>

  <section class="section-tight shell">
    <div class="section-heading">
      <h2>Browse the Database</h2>
      <p>Open the current vehicle, character, location, and edition collections.</p>
    </div>
    <div class="content-grid">
      {gta6DatabaseCards.map((card) => (
        <article class="content-card">
          <a class="news-card-media" href={card.href} aria-label={card.title}><GuideMedia id={card.mediaId} sizes="(max-width: 720px) 100vw, 25vw" /></a>
          <h3><a href={card.href}>{card.title}</a></h3>
          <p>{card.deck}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
