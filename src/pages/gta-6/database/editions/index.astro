---
import Gta6Rail from "@components/Gta6Rail.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import GuideMedia from "@components/GuideMedia.astro";
import { editionDatabaseRows } from "@data/gta6";
import { sourceById } from "@data/sources";
import { site } from "@data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "GTA 6 Edition Database",
    description: "A source-labeled GTA 6 editions and preorder database for prices, bonuses, GTA+ benefits, and preload records.",
    url: `${site.url}/gta-6/database/editions/`
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "GTA 6 edition and preorder records",
    numberOfItems: editionDatabaseRows.length,
    itemListElement: editionDatabaseRows.map((row, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: row.name,
      url: `${site.url}${row.page}`
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url },
      { "@type": "ListItem", position: 2, name: "GTA 6", item: `${site.url}/gta-6/` },
      { "@type": "ListItem", position: 3, name: "Database", item: `${site.url}/gta-6/database/` },
      { "@type": "ListItem", position: 4, name: "Editions", item: `${site.url}/gta-6/database/editions/` }
    ]
  }
];
---

<BaseLayout
  title="GTA 6 Edition Database"
  description="Official GTA 6 editions and preorder details, with confirmation notes, official links, and current buyer guides."
  schema={schema}
>
  <header class="page-header shell">
    <div class="page-kicker">Editions database</div>
    <h1 class="page-title">GTA 6 Edition Database</h1>
    <p class="page-intro">
      Compare officially announced editions, prices, preorder benefits, and preload details before choosing a version.
    </p>
  </header>

  <Gta6Rail />

  <section class="section-tight shell">
    <table class="source-table vehicle-table database-table">
      <thead>
        <tr>
          <th>Record</th>
          <th>Status</th>
          <th>What is confirmed</th>
          <th>Source</th>
        </tr>
      </thead>
      <tbody>
        {editionDatabaseRows.map((row) => {
          const source = sourceById[row.sourceId];
          return (
            <tr>
              <td data-label="Record"><GuideMedia id={row.mediaId} /><strong><a href={row.page}>{row.name}</a></strong></td>
              <td data-label="Status"><span class="badge official">{row.status}</span></td>
              <td data-label="What is confirmed">{row.proof}</td>
              <td data-label="Source"><a href={source.url} target="_blank" rel="nofollow noopener">{source.publisher}</a></td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </section>

  <section class="section-tight shell split">
    <article class="panel">
      <h2>What is confirmed</h2>
      <p>
        Rockstar now lists the Ultimate Edition items, the Vintage Vice City Pack contents, upgrade path, code-in-box format, and preload timing.
      </p>
    </article>
    <article class="panel">
      <h2>What this means for players</h2>
      <p>Use the <a href="/guides/gta-6-pre-order-standard-vs-ultimate/">preorder comparison</a> to choose between editions and check current bonus details.</p>
    </article>
  </section>
</BaseLayout>
