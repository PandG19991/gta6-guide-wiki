---
import Gta6Rail from "@components/Gta6Rail.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import GuideMedia from "@components/GuideMedia.astro";
import { characterDatabaseRows } from "@data/gta6";
import { sourceById } from "@data/sources";
import { site } from "@data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "GTA 6 Character Database",
    description: "Official GTA 6 character profiles with current confirmation notes and links to player guides.",
    url: `${site.url}/gta-6/database/characters/`
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "GTA 6 official character records",
    numberOfItems: characterDatabaseRows.length,
    itemListElement: characterDatabaseRows.map((row, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: row.name,
      url: `${site.url}${row.page}`
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url },
      { "@type": "ListItem", position: 2, name: "GTA 6", item: `${site.url}/gta-6/` },
      { "@type": "ListItem", position: 3, name: "Database", item: `${site.url}/gta-6/database/` },
      { "@type": "ListItem", position: 4, name: "Characters", item: `${site.url}/gta-6/database/characters/` }
    ]
  }
];
---

<BaseLayout
  title="GTA 6 Character Database"
  description="Official GTA 6 character profiles with confirmation notes, official links, and current player guides."
  schema={schema}
>
  <header class="page-header shell">
    <div class="page-kicker">Characters database</div>
    <h1 class="page-title">GTA 6 Character Database</h1>
    <p class="page-intro">
      Browse GTA 6 characters profiled by Rockstar, with direct links to current character guides.
    </p>
  </header>

  <Gta6Rail />

  <section class="section-tight shell">
    <table class="source-table vehicle-table">
      <thead>
        <tr>
          <th>Character</th>
          <th>Status</th>
          <th>What is confirmed</th>
          <th>Source</th>
        </tr>
      </thead>
      <tbody>
        {characterDatabaseRows.map((row) => {
          const source = sourceById[row.sourceId];
          return (
            <tr>
              <td data-label="Character"><GuideMedia id={row.mediaId} /><strong><a href={row.page}>{row.name}</a></strong></td>
              <td data-label="Status"><span class="badge official">{row.status}</span></td>
              <td data-label="What is confirmed">{row.proof}</td>
              <td data-label="Source"><a href={source.url} target="_blank" rel="nofollow noopener">{source.publisher}</a></td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </section>

  <section class="section-tight shell split">
    <article class="panel">
      <h2>What is confirmed</h2>
      <p>
        Rockstar profiles Jason Duval, Lucia Caminos, and the supporting characters listed above on its official Leonida page.
      </p>
    </article>
    <article class="panel">
      <h2>What this means for players</h2>
      <p>Open the <a href="/guides/gta-6-characters-official-cast/">official cast guide</a> for concise profiles of Jason, Lucia, and the supporting cast.</p>
    </article>
  </section>
</BaseLayout>
