---
import Gta6Rail from "@components/Gta6Rail.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import ConfidenceBadge from "@components/ConfidenceBadge.astro";
import { gta6DatabaseCards } from "@data/gta6";
import { site } from "@data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "GTA 6 Database",
    description: "Browse GTA 6 vehicles, characters, locations, and editions from one database hub.",
    url: `${site.url}/gta-6/database/`
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "GTA 6 database categories",
    numberOfItems: gta6DatabaseCards.length,
    itemListElement: gta6DatabaseCards.map((section, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: section.title,
      url: `${site.url}${section.href}`
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url },
      { "@type": "ListItem", position: 2, name: "GTA 6", item: `${site.url}/gta-6/` },
      { "@type": "ListItem", position: 3, name: "Database", item: `${site.url}/gta-6/database/` }
    ]
  }
];
---

<BaseLayout
  title="GTA 6 Database"
  description="Browse GTA 6 vehicles, characters, locations, and editions from one database hub."
  schema={schema}
>
  <header class="page-header shell">
    <div class="page-kicker">Database</div>
    <h1 class="page-title">GTA 6 Database</h1>
    <p class="page-intro">
      Choose a category to browse the GTA 6 information currently available for players.
    </p>
  </header>

  <Gta6Rail />

  <section class="section-tight shell">
    <div class="database-category-grid">
      {gta6DatabaseCards.map((section) => (
        <article class="database-category-card">
          <div class="card-meta">
            <ConfidenceBadge value={section.confidence} />
          </div>
          <h2><a href={section.href}>{section.title}</a></h2>
          <p>{section.deck}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
