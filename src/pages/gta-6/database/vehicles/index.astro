---
import Gta6Rail from "@components/Gta6Rail.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import GuideMedia from "@components/GuideMedia.astro";
import { sourceById } from "@data/sources";
import { vehicleDatabaseRows } from "@data/gta6";
import { site } from "@data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "GTA 6 Vehicle Database",
    description: "GTA 6 vehicle categories shown in official material, with current confirmation notes and links to player guides.",
    url: `${site.url}/gta-6/database/vehicles/`
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "GTA 6 vehicle categories",
    numberOfItems: vehicleDatabaseRows.length,
    itemListElement: vehicleDatabaseRows.map((row, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: row.category,
      url: `${site.url}${row.page}`
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url },
      { "@type": "ListItem", position: 2, name: "GTA 6", item: `${site.url}/gta-6/` },
      { "@type": "ListItem", position: 3, name: "Database", item: `${site.url}/gta-6/database/` },
      { "@type": "ListItem", position: 4, name: "Vehicles", item: `${site.url}/gta-6/database/vehicles/` }
    ]
  }
];
---

<BaseLayout
  title="GTA 6 Vehicle Database"
  description="GTA 6 vehicle categories shown in official material, with confirmation notes, official links, and current player guides."
  schema={schema}
>
  <header class="page-header shell">
    <div class="page-kicker">Vehicles database</div>
    <h1 class="page-title">GTA 6 Vehicle Database</h1>
    <p class="page-intro">
      Browse vehicle classes shown in official GTA 6 material, with direct links to current vehicle guides.
    </p>
  </header>

  <Gta6Rail />

  <section class="section-tight shell">
    <table class="source-table vehicle-table database-table">
      <thead>
        <tr>
          <th>Category</th>
          <th>Status</th>
          <th>What is confirmed</th>
          <th>Source</th>
        </tr>
      </thead>
      <tbody>
        {vehicleDatabaseRows.map((row) => {
          const source = sourceById[row.sourceId];
          return (
            <tr>
              <td data-label="Category"><GuideMedia id={row.mediaId} /><strong><a href={row.page}>{row.category}</a></strong></td>
              <td data-label="Status"><span class={`badge ${row.status.toLowerCase()}`}>{row.status}</span></td>
              <td data-label="What is confirmed">{row.proof}</td>
              <td data-label="Source"><a href={source.url} target="_blank" rel="nofollow noopener">{source.publisher}</a></td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </section>

  <section class="section-tight shell split">
    <article class="panel">
      <h2>What is confirmed</h2>
      <p>
        Official media shows street cars, motorcycles, watercraft, aircraft, and emergency vehicles. Exact model names remain limited to what Rockstar identifies clearly.
      </p>
    </article>
    <article class="panel">
      <h2>What this means for players</h2>
      <p>Use the <a href="/guides/gta-6-vehicles-confirmed-so-far/">confirmed vehicles guide</a> for the current list and official media links.</p>
    </article>
  </section>
</BaseLayout>
