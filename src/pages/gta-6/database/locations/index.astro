---
import Gta6Rail from "@components/Gta6Rail.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { locationDatabaseRows } from "@data/gta6";
import { sourceById } from "@data/sources";
import { site } from "@data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "GTA 6 Location Database",
    description: "A source-labeled GTA 6 location database for official Leonida destinations and launch-week verification needs.",
    url: `${site.url}/gta-6/database/locations/`
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "GTA 6 official location records",
    numberOfItems: locationDatabaseRows.length,
    itemListElement: locationDatabaseRows.map((row, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: row.name,
      url: `${site.url}${row.page}`
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url },
      { "@type": "ListItem", position: 2, name: "GTA 6", item: `${site.url}/gta-6/` },
      { "@type": "ListItem", position: 3, name: "Database", item: `${site.url}/gta-6/database/` },
      { "@type": "ListItem", position: 4, name: "Locations", item: `${site.url}/gta-6/database/locations/` }
    ]
  }
];
---

<BaseLayout
  title="GTA 6 Location Database"
  description="Official GTA 6 location database with proof notes, source links, and launch-week verification targets without leaked map coordinates."
  schema={schema}
>
  <header class="page-header shell">
    <div class="page-kicker">Locations database</div>
    <h1 class="page-title">GTA 6 Location Database</h1>
    <p class="page-intro">
      Official Leonida destinations in one source-led table, with launch-week fields reserved for verified markers, routes, and activity notes.
    </p>
  </header>

  <Gta6Rail />

  <section class="section-tight shell">
    <table class="source-table vehicle-table">
      <thead>
        <tr>
          <th>Location</th>
          <th>Status</th>
          <th>Proof note</th>
          <th>Launch use</th>
          <th>Source</th>
        </tr>
      </thead>
      <tbody>
        {locationDatabaseRows.map((row) => {
          const source = sourceById[row.sourceId];
          return (
            <tr>
              <td data-label="Location"><strong><a href={row.page}>{row.name}</a></strong></td>
              <td data-label="Status"><span class="badge official">{row.status}</span></td>
              <td data-label="Proof note">{row.proof}</td>
              <td data-label="Launch use">{row.launchUse}</td>
              <td data-label="Source"><a href={source.url} target="_blank" rel="nofollow noopener">{source.publisher}</a></td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </section>

  <section class="section-tight shell split">
    <article class="panel">
      <h2>What stays out?</h2>
      <p>
        Leaked map outlines, guessed coordinates, collectible routes, property lists, and activity-density claims stay out until official copy or repeatable launch testing supports them.
      </p>
    </article>
    <article class="panel">
      <h2>Launch checklist</h2>
      <ul>
        <li>Record region boundary, access route, marker type, spoiler level, and platform.</li>
        <li>Separate official destination names from player-tested map details.</li>
        <li>Link each update to a source, date, route, and repeatable proof note.</li>
      </ul>
    </article>
  </section>
</BaseLayout>
