---
import BaseLayout from "@layouts/BaseLayout.astro";
import NewsGuideCard from "@components/NewsGuideCard.astro";
import { publicGuides } from "@data/guides";
import { publicLedgerUpdates } from "@data/updates";
import { site } from "@data/site";

const recentGuides = [...publicGuides].sort((a, b) => b.updated.localeCompare(a.updated)).slice(0, 8);
const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "GTA 6 News And Guide Updates",
  url: `${site.url}/updates/`,
  description: "Latest official GTA 6 announcements and newly updated player guides from Leonida Ledger.",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: recentGuides.map((guide, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: guide.title,
      url: `${site.url}/guides/${guide.slug}/`
    }))
  }
};
---

<BaseLayout title="GTA 6 News And Guide Updates" description="Latest official GTA 6 announcements and newly updated player guides from Leonida Ledger." schema={schema}>
  <header class="page-header news-header shell">
    <h1 class="page-title">GTA 6 News And Guide Updates</h1>
    <p class="page-intro">
      Browse the latest updated GTA 6 guides and official release and preorder announcements.
    </p>
  </header>

  <section class="section-tight news-section shell">
    <div class="section-heading">
      <h2>Latest GTA 6 News And Guides</h2>
      <p>Open the latest release, buying, map, character, and vehicle guides.</p>
    </div>
    <div class="content-grid">
      {recentGuides.slice(0, 6).map((guide) => <NewsGuideCard guide={guide} />)}
    </div>
  </section>

  <section class="section-tight shell">
    <div class="section-heading">
      <h2>Official Announcements</h2>
      <p>Key GTA 6 release and preorder news from Rockstar Games and Take-Two Interactive.</p>
    </div>
    <table class="source-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Announcement</th>
          <th>From</th>
        </tr>
      </thead>
      <tbody>
        {publicLedgerUpdates.map((update) => (
          <tr>
            <td class="mono">{update.date}</td>
            <td><a href={update.url} target="_blank" rel="nofollow noopener"><strong>{update.title}</strong></a></td>
            <td>{update.source}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

</BaseLayout>
