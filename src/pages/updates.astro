---
import BaseLayout from "@layouts/BaseLayout.astro";
import ConfidenceBadge from "@components/ConfidenceBadge.astro";
import NewsGuideCard from "@components/NewsGuideCard.astro";
import { guides } from "@data/guides";
import { ledgerUpdates } from "@data/updates";
import { site } from "@data/site";

const recentGuides = [...guides].sort((a, b) => b.updated.localeCompare(a.updated)).slice(0, 8);
const launchQueue = guides.filter((guide) => guide.status === "launch-week").slice(0, 6);
const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "GTA 6 News And Guide Updates",
  url: `${site.url}/updates/`,
  description: "Latest GTA 6 guide updates, source checks, publishing queue, and transparent change log for Leonida Ledger.",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: recentGuides.map((guide, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: guide.title,
      url: `${site.url}/guides/${guide.slug}/`
    }))
  }
};
---

<BaseLayout title="GTA 6 News And Guide Updates" description="Latest GTA 6 guide updates, source checks, publishing queue, and transparent change log for Leonida Ledger." schema={schema}>
  <header class="page-header news-header shell">
    <div class="page-kicker">GTA 6 news desk</div>
    <h1 class="page-title">GTA 6 News And Guide Updates</h1>
    <p class="page-intro">
      Latest guide refreshes, source checks, and launch-week publishing priorities, with the full evidence ledger kept below.
    </p>
  </header>

  <section class="section-tight news-section shell">
    <div class="section-heading">
      <h2>Latest GTA 6 News And Guides</h2>
      <p>Start with the player-facing updates. Each card links to a guide page that can rank, refresh, and grow as official or tested details arrive.</p>
    </div>
    <div class="content-grid">
      {recentGuides.slice(0, 6).map((guide) => <NewsGuideCard guide={guide} />)}
    </div>
  </section>

  <section class="section-tight shell">
    <div class="section-heading">
      <h2>Source Ledger</h2>
      <p>Every meaningful factual change still leaves a trail: date, confidence, source, and what changed.</p>
    </div>
    <table class="ledger-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Confidence</th>
          <th>Change</th>
          <th>Source</th>
        </tr>
      </thead>
      <tbody>
        {ledgerUpdates.map((update) => (
          <tr>
            <td class="mono">{update.date}<br />{update.time}</td>
            <td><ConfidenceBadge value={update.confidence} /></td>
            <td>{update.title}</td>
            <td>{update.source}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section class="section-tight shell split">
    <div>
      <h2 class="page-title">Next Queue</h2>
      <p class="page-intro">
        These launch-week pages are intentionally live as stable URLs, but will not pretend to know unverified mechanics before release.
      </p>
    </div>
    <div class="panel">
      {launchQueue.map((guide) => (
        <section>
          <h3><a href={`/guides/${guide.slug}/`}>{guide.title}</a></h3>
          <p>{guide.nextUpdate}</p>
        </section>
      ))}
      <section>
        <h3>Machine Feeds</h3>
        <p><a href="/sitemap.xml">Sitemap</a> / <a href="/feed.xml">RSS feed</a></p>
      </section>
    </div>
  </section>
</BaseLayout>
