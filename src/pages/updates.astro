---
import BaseLayout from "@layouts/BaseLayout.astro";
import NewsGuideCard from "@components/NewsGuideCard.astro";
import { publicGuides } from "@data/guides";
import { publicUpdates } from "@data/updates";
import { site } from "@data/site";

const recentGuides = [...publicGuides].sort((a, b) => b.updated.localeCompare(a.updated)).slice(0, 8);
const affectedTitles = new Map<string, string>([
  ...publicGuides.map((guide) => [`/guides/${guide.slug}/`, guide.title] as const),
  ["/gta-6/database/editions/", "GTA 6 Edition Database"] as const
]);
const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "GTA 6 Updates",
  url: `${site.url}/updates/`,
  description: "Official GTA 6 changes connected to the player guides and database pages they affect.",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: recentGuides.map((guide, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: guide.title,
      url: `${site.url}/guides/${guide.slug}/`
    }))
  }
};
---

<BaseLayout title="GTA 6 Updates" description="Official GTA 6 changes connected to the player guides and database pages they affect." schema={schema}>
  <header class="page-header news-header shell">
    <h1 class="page-title">GTA 6 Updates</h1>
    <p class="page-intro">
      See the official changes that altered a current player answer, then open the affected guide for the durable details.
    </p>
  </header>

  <section class="section-tight news-section shell">
    <div class="section-heading">
      <h2>Recently Updated Guides</h2>
      <p>Open the latest release, buying, map, character, and vehicle guides.</p>
    </div>
    <div class="content-grid">
      {recentGuides.slice(0, 6).map((guide) => <NewsGuideCard guide={guide} />)}
    </div>
  </section>

  <section class="section-tight shell">
    <div class="section-heading">
      <h2>Meaningful Official Changes</h2>
      <p>Each change links to the guide or database page where the answer is maintained.</p>
    </div>
    <table class="source-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Announcement</th>
          <th>From</th>
        </tr>
      </thead>
      <tbody>
        {publicUpdates.map((update) => (
          <tr>
            <td class="mono">{update.date}</td>
            <td>
              <a href={update.url} target="_blank" rel="noopener"><strong>{update.title}</strong></a>
              <div class="affected-links">
                {update.affectedRoutes.map((route) => <a href={route}>{affectedTitles.get(route) ?? "Affected page"}</a>)}
              </div>
            </td>
            <td>{update.source}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

</BaseLayout>
