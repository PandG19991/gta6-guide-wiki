---
import BaseLayout from "@layouts/BaseLayout.astro";
import ConfidenceBadge from "@components/ConfidenceBadge.astro";
import GuideCard from "@components/GuideCard.astro";
import { confidenceLevels, site } from "@data/site";
import { guides } from "@data/guides";
import { ledgerUpdates } from "@data/updates";
import { contentClusters, competitorPatterns } from "@data/contentPlan";

const heroGuideSlugs = [
  "gta-6-release-date-countdown-preload",
  "is-gta-6-coming-to-pc",
  "gta-6-pre-order-standard-vs-ultimate",
  "gta-6-map-leonida-regions-evidence-tracker"
];

const heroGuides = heroGuideSlugs
  .map((slug) => guides.find((guide) => guide.slug === slug))
  .filter((guide): guide is (typeof guides)[number] => Boolean(guide));

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  url: site.url,
  description: site.description,
  potentialAction: {
    "@type": "SearchAction",
    target: `${site.url}/guides/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};
---

<BaseLayout title="GTA 6 Guide Hub" description={site.description} schema={schema}>
  <section class="hero">
    <div class="hero-copy">
      <h1>GTA 6 Guide Hub</h1>
      <span class="coral-rule" aria-hidden="true"></span>
      <p>Fast answers for release date, PC status, preload, preorder, map, characters, vehicles, missions, and cheats.</p>
      <form class="hero-search" action="/guides/" method="get">
        <input class="field" type="search" name="q" placeholder="Search PC, preload, map, cheats..." aria-label="Search GTA 6 guides" />
        <button class="button" type="submit">Search Guides</button>
      </form>
      <nav class="hero-jump-row" aria-label="Popular guide categories">
        <a href="/guides/category/release/">Release</a>
        <a href="/guides/category/buying/">Buying</a>
        <a href="/guides/category/map/">Map</a>
        <a href="/guides/category/cheats/">Cheats</a>
      </nav>
    </div>
    <aside class="hero-guide-panel" aria-label="Top GTA 6 guide paths">
      <div class="hero-art">
        <img src="/assets/hero-leonida-dossier.png" alt="Original illustrated map desk for the Leonida Ledger guide hub" />
      </div>
      <div class="hero-panel-content">
        <h2>Start Here</h2>
        <div class="hero-quick-list">
          {heroGuides.map((guide) => (
            <a href={`/guides/${guide.slug}/`}>
              <span>{guide.title.replace("GTA 6 ", "")}</span>
              <small>{guide.confidence} / {guide.intent}</small>
            </a>
          ))}
        </div>
      </div>
    </aside>
    <div class="facts-strip" aria-label="Current official GTA 6 facts">
      <div class="fact">
        <b>Release</b>
        <span>Nov 19, 2026</span>
      </div>
      <div class="fact">
        <b>Platforms</b>
        <span>PS5 / Xbox Series X|S</span>
      </div>
      <div class="fact">
        <b>Preload</b>
        <span>Nov 12, 2026</span>
      </div>
      <div class="fact">
        <b>Site Mode</b>
        <span>Evidence-first</span>
      </div>
    </div>
  </section>

  <section class="section shell" id="launch-prep">
    <div class="section-heading">
      <h2>Guide Board</h2>
      <p>
        Built for the searches people are already making: release date, map, wiki, guide, cheats,
        missions, cars, preorder, weapons, and locations. Unknowns stay marked unknown until official or tested.
      </p>
    </div>

    <div class="guide-board">
      <aside class="confidence-rail" aria-label="Confidence labels">
        {confidenceLevels.map((level) => (
          <div class="confidence-item">
            <span class="confidence-dot" style={`background: var(--${level.tone});`}>{level.label.slice(0, 1)}</span>
            <div>
              <h3>{level.label}</h3>
              <p>{level.description}</p>
            </div>
          </div>
        ))}
      </aside>
      <div>
        <form class="toolbar" data-guide-filters>
          <input class="field" type="search" name="q" placeholder="Search guides, locations, vehicles, and more..." aria-label="Search guides" />
          <select class="field" name="intent" aria-label="Filter by search phase">
            <option value="all">Topic: All</option>
            <option value="pre-launch">Pre-launch</option>
            <option value="launch-week">Launch week</option>
            <option value="evergreen">Evergreen</option>
          </select>
          <select class="field" name="confidence" aria-label="Filter by confidence">
            <option value="all">Confidence: Any</option>
            {confidenceLevels.map((level) => <option value={level.key}>{level.label}</option>)}
          </select>
        </form>
        <div class="guide-list" data-guide-list>
          {guides.map((guide) => <GuideCard guide={guide} />)}
        </div>
      </div>
    </div>
  </section>

  <section class="section-tight shell">
    <div class="section-heading">
      <h2>Ledger Updates</h2>
      <p>Every factual change gets a timestamp, confidence label, and source trail. This keeps the site useful before launch without inventing post-launch details.</p>
    </div>
    <table class="ledger-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Confidence</th>
          <th>Change</th>
          <th>Source</th>
        </tr>
      </thead>
      <tbody>
        {ledgerUpdates.map((update) => (
          <tr>
            <td class="mono">{update.date}<br />{update.time}</td>
            <td><ConfidenceBadge value={update.confidence} /></td>
            <td>{update.title}</td>
            <td>{update.source}</td>
          </tr>
        ))}
      </tbody>
    </table>
    <div class="section-actions">
      <a class="button secondary" href="/updates/">View All Updates</a>
    </div>
  </section>

  <section class="section shell">
    <div class="section-heading">
      <h2>Content Engine</h2>
      <p>
        The site is planned as a living guide product. Pre-launch pages answer official questions,
        launch-week pages convert into tested walkthroughs, and evergreen pages become repeat-visit databases.
      </p>
    </div>
    <div class="content-grid">
      {contentClusters.map((cluster) => (
        <article class="content-card">
          <div class="card-meta">
            <span class="badge analysis">{cluster.phase}</span>
          </div>
          <h3>{cluster.phase}</h3>
          <p>{cluster.purpose}</p>
          <div class="card-actions">
            <strong class="meta-label">First pages</strong>
            <p>{cluster.pages.slice(0, 4).join(" / ")}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-tight shell split">
    <div>
      <h2 class="page-title">Not A Stiff Wiki</h2>
      <p class="page-intro">
        We borrow the useful parts of big guide sites: hubs, databases, citations, maps, and launch checklists.
        We avoid the low-value parts: scraped summaries, unverified leak lists, fake walkthroughs, and pages with no actionable answer.
      </p>
    </div>
    <div class="panel">
      {competitorPatterns.map((pattern) => (
        <section>
          <h3>{pattern.site}</h3>
          <p><strong>Pattern:</strong> {pattern.copy}</p>
          <p><strong>Adaptation:</strong> {pattern.adaptation}</p>
        </section>
      ))}
    </div>
  </section>

  <script>
    const form = document.querySelector("[data-guide-filters]");
    const cards = Array.from(document.querySelectorAll("[data-guide-card]"));
    const applyFilters = () => {
      if (!form) return;
      const data = new FormData(form as HTMLFormElement);
      const query = String(data.get("q") || "").trim().toLowerCase();
      const intent = String(data.get("intent") || "all");
      const confidence = String(data.get("confidence") || "all");
      cards.forEach((card) => {
        const el = card as HTMLElement;
        const text = el.getAttribute("data-search") || "";
        const matchesQuery = !query || text.includes(query);
        const matchesIntent = intent === "all" || el.getAttribute("data-intent") === intent;
        const matchesConfidence = confidence === "all" || el.getAttribute("data-confidence") === confidence;
        el.hidden = !(matchesQuery && matchesIntent && matchesConfidence);
      });
    };
    form?.addEventListener("input", applyFilters);
  </script>
</BaseLayout>
