---
import BaseLayout from "@layouts/BaseLayout.astro";
import GuideCard from "@components/GuideCard.astro";
import NewsGuideCard from "@components/NewsGuideCard.astro";
import GuideMedia from "@components/GuideMedia.astro";
import { site } from "@data/site";
import { publicGuides } from "@data/guides";
import { publicUpdates } from "@data/updates";

const guidePaths = [
  { title: "Release & Platforms", deck: "Release date, preload, consoles, and PC status.", href: "/release/", mediaId: "cover-art" },
  { title: "Map & Locations", deck: "Vice City, the Keys, and every confirmed region.", href: "/map/", mediaId: "vice-city" },
  { title: "Characters", deck: "Jason, Lucia, supporting cast, and story connections.", href: "/guides/category/characters/", mediaId: "jason-lucia" },
  { title: "Vehicles", deck: "Cars, bikes, boats, aircraft, and official sightings.", href: "/gta-6/database/vehicles/", mediaId: "grotti-cheetah" },
  { title: "Buying & Editions", deck: "Standard, Ultimate, preorder bonuses, and value.", href: "/guides/category/buying/", mediaId: "vintage-pack" }
] as const;
const latestGuides = [...publicGuides].sort((a, b) => b.updated.localeCompare(a.updated)).slice(0, 3);
const latestUpdates = publicUpdates.slice(0, 2);

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  url: site.url,
  description: site.description,
  potentialAction: {
    "@type": "SearchAction",
    target: `${site.url}/guides/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};
---

<BaseLayout title="GTA 6 Guide Hub" description={site.description} schema={schema}>
  <section class="hero">
    <div class="hero-background">
      <GuideMedia id="vice-city" priority sizes="100vw" />
    </div>
    <div class="hero-copy shell">
      <div class="hero-copy-inner">
        <h1>GTA 6 Guide Hub</h1>
        <p>Fast answers for release date, PC status, preload, preorder, map, characters, vehicles, and editions.</p>
        <form class="hero-search" action="/guides/" method="get">
          <input class="field" type="search" name="q" placeholder="Search GTA 6 guides" aria-label="Search GTA 6 guides" />
          <button class="button" type="submit">Search Guides</button>
        </form>
      </div>
    </div>
  </section>

  <section class="facts-band" aria-label="Current official GTA 6 facts">
    <div class="facts-strip shell">
      <div class="fact"><b>Release</b><span>Nov 19, 2026</span></div>
      <div class="fact"><b>Platforms</b><span>PS5 / Xbox Series X|S</span></div>
      <div class="fact"><b>Preload</b><span>Nov 12, 2026</span></div>
      <div class="fact"><b>Starting Price</b><span>$79.99</span></div>
    </div>
  </section>

  <section class="guide-path-section shell" aria-labelledby="guide-path-title">
    <div class="section-heading compact-heading">
      <h2 id="guide-path-title">Explore Key Guide Paths</h2>
    </div>
    <nav class="guide-path-grid" aria-label="GTA 6 guide paths">
      {guidePaths.map((path) => (
        <a class="guide-path" href={path.href}>
          <GuideMedia id={path.mediaId} sizes="(max-width: 720px) 42vw, 20vw" />
          <span class="guide-path-copy">
            <strong>{path.title}</strong>
            <small>{path.deck}</small>
          </span>
          <b aria-hidden="true">→</b>
        </a>
      ))}
    </nav>
  </section>

  <section class="section-tight shell home-split">
    <div>
      <div class="section-heading compact-heading">
        <h2>Latest Guides</h2>
        <a href="/updates/">View updates →</a>
      </div>
      <div class="content-grid">
        {latestGuides.map((guide) => <NewsGuideCard guide={guide} />)}
      </div>
    </div>
    <aside class="update-list" aria-label="Latest official announcements">
      <div class="section-heading compact-heading"><h2>Official Updates</h2></div>
      {latestUpdates.map((update) => (
        <a href={update.affectedRoutes[0]}><time>{update.date}</time><strong>{update.title}</strong><span>→</span></a>
      ))}
      <a class="update-list-more" href="/updates/">All GTA 6 updates</a>
    </aside>
  </section>

  <section class="section shell" id="launch-prep">
    <div class="section-heading">
      <h2>All GTA 6 Guides</h2>
      <p>Browse release, buying, map, character, vehicle, and spoiler-safe preparation guides.</p>
    </div>

    <form class="toolbar" data-guide-filters>
      <input class="field" type="search" name="q" placeholder="Search guides, locations, vehicles, and more..." aria-label="Search guides" />
    </form>
    <div class="guide-list" data-guide-list>
      {publicGuides.map((guide) => <GuideCard guide={guide} />)}
    </div>
  </section>

  <script>
    const form = document.querySelector("[data-guide-filters]");
    const cards = Array.from(document.querySelectorAll("[data-guide-card]"));
    const applyFilters = () => {
      if (!form) return;
      const data = new FormData(form as HTMLFormElement);
      const query = String(data.get("q") || "").trim().toLowerCase();
      cards.forEach((card) => {
        const el = card as HTMLElement;
        const text = el.getAttribute("data-search") || "";
        el.hidden = Boolean(query) && !text.includes(query);
      });
    };
    form?.addEventListener("input", applyFilters);
  </script>
</BaseLayout>
