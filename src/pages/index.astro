---
import BaseLayout from "@layouts/BaseLayout.astro";
import GuideCard from "@components/GuideCard.astro";
import NewsGuideCard from "@components/NewsGuideCard.astro";
import { site } from "@data/site";
import { publicGuideCategoryMeta, publicGuides } from "@data/guides";
import { publicLedgerUpdates } from "@data/updates";

const heroGuideSlugs = [
  "gta-6-release-date-countdown-preload",
  "is-gta-6-coming-to-pc",
  "gta-6-pre-order-standard-vs-ultimate",
  "gta-6-map-leonida-regions-evidence-tracker"
];

const heroGuides = heroGuideSlugs
  .map((slug) => publicGuides.find((guide) => guide.slug === slug))
  .filter((guide): guide is (typeof publicGuides)[number] => Boolean(guide));
const latestGuides = [...publicGuides].sort((a, b) => b.updated.localeCompare(a.updated)).slice(0, 3);
const latestUpdates = publicLedgerUpdates.slice(0, 2);

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  url: site.url,
  description: site.description,
  potentialAction: {
    "@type": "SearchAction",
    target: `${site.url}/guides/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};
---

<BaseLayout title="GTA 6 Guide Hub" description={site.description} schema={schema}>
  <section class="hero">
    <div class="hero-copy">
      <h1>GTA 6 Guide Hub</h1>
      <span class="coral-rule" aria-hidden="true"></span>
      <p>Fast answers for release date, PC status, preload, preorder, map, characters, vehicles, missions, and cheats.</p>
      <form class="hero-search" action="/guides/" method="get">
        <input class="field" type="search" name="q" placeholder="Search PC, preload, map, cheats..." aria-label="Search GTA 6 guides" />
        <button class="button" type="submit">Search Guides</button>
      </form>
      <nav class="hero-jump-row" aria-label="Popular guide categories">
        {publicGuideCategoryMeta.slice(0, 4).map((meta) => (
          <a href={`/guides/category/${meta.slug}/`}>{meta.category}</a>
        ))}
      </nav>
    </div>
    <aside class="hero-guide-panel" aria-label="Top GTA 6 guide paths">
      <div class="hero-art">
        <img src="/assets/hero-leonida-dossier.png" alt="Original illustrated map desk for the Leonida Ledger guide hub" />
      </div>
      <div class="hero-panel-content">
        <h2>Start Here</h2>
        <div class="hero-quick-list">
          {heroGuides.map((guide) => (
            <a href={`/guides/${guide.slug}/`}>
              <span>{guide.title.replace("GTA 6 ", "")}</span>
              <small>{guide.category}</small>
            </a>
          ))}
        </div>
      </div>
    </aside>
    <div class="facts-strip" aria-label="Current official GTA 6 facts">
      <div class="fact">
        <b>Release</b>
        <span>Nov 19, 2026</span>
      </div>
      <div class="fact">
        <b>Platforms</b>
        <span>PS5 / Xbox Series X|S</span>
      </div>
      <div class="fact">
        <b>Preload</b>
        <span>Nov 12, 2026</span>
      </div>
      <div class="fact">
        <b>Starting Price</b>
        <span>$79.99</span>
      </div>
    </div>
  </section>

  <section class="section-tight shell">
    <div class="section-heading">
      <h2>Latest GTA 6 News And Guides</h2>
      <p>Official announcements, buying decisions, and practical launch guides for GTA 6 players.</p>
    </div>
    <div class="content-grid">
      {latestGuides.map((guide) => <NewsGuideCard guide={guide} />)}
    </div>
    <div class="section-actions">
      {latestUpdates.map((update) => (
        <a class="button secondary" href="/updates/">{update.date}: {update.title}</a>
      ))}
    </div>
  </section>

  <section class="section shell" id="launch-prep">
    <div class="section-heading">
      <h2>Guide Board</h2>
      <p>Browse release, buying, map, character, vehicle, mission, and launch-preparation guides.</p>
    </div>

    <form class="toolbar" data-guide-filters>
      <input class="field" type="search" name="q" placeholder="Search guides, locations, vehicles, and more..." aria-label="Search guides" />
    </form>
    <div class="guide-list" data-guide-list>
      {publicGuides.map((guide) => <GuideCard guide={guide} />)}
    </div>
  </section>

  <script>
    const form = document.querySelector("[data-guide-filters]");
    const cards = Array.from(document.querySelectorAll("[data-guide-card]"));
    const applyFilters = () => {
      if (!form) return;
      const data = new FormData(form as HTMLFormElement);
      const query = String(data.get("q") || "").trim().toLowerCase();
      cards.forEach((card) => {
        const el = card as HTMLElement;
        const text = el.getAttribute("data-search") || "";
        el.hidden = Boolean(query) && !text.includes(query);
      });
    };
    form?.addEventListener("input", applyFilters);
  </script>
</BaseLayout>
