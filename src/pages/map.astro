---
import BaseLayout from "@layouts/BaseLayout.astro";
import GuideMedia from "@components/GuideMedia.astro";

const regions = [
  ["Vice City", "Urban center and story anchor"],
  ["Leonida Keys", "Island and coastal region"],
  ["Grassrivers", "Wetlands region"],
  ["Port Gellhorn", "Coastal destination"],
  ["Ambrosia", "Named Leonida destination"],
  ["Mount Kalaga", "Northern destination"]
] as const;
---

<BaseLayout title="GTA 6 Map and Leonida Locations" description="Official GTA 6 locations across Leonida, including Vice City, Leonida Keys, Grassrivers, Port Gellhorn, Ambrosia, and Mount Kalaga." image="/assets/og-map.png">
  <header class="page-header shell">
    <h1 class="page-title">GTA 6 Map and Leonida Locations</h1>
    <p class="page-intro">
      Rockstar has named six Leonida destinations. Use the region board and location guides below for the currently confirmed map information.
    </p>
  </header>

  <section class="section-tight shell">
    <GuideMedia id="vice-city" priority attribution sizes="(max-width: 900px) 100vw, 900px" />
  </section>

  <section class="section-tight shell split">
    <div class="panel">
      <h2>Official Region Board</h2>
      <table class="database-table">
        <thead>
          <tr>
            <th>Region</th>
            <th>Role</th>
          </tr>
        </thead>
        <tbody>
          {regions.map(([name, role]) => (
            <tr>
              <td data-label="Region"><strong>{name}</strong></td>
              <td data-label="Role">{role}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="panel">
      <h2>Location Guides</h2>
      <ul>
        <li><a href="/guides/gta-6-vice-city-location-guide/">Vice City</a></li>
        <li><a href="/guides/gta-6-leonida-keys-location-guide/">Leonida Keys</a></li>
        <li><a href="/guides/gta-6-map-leonida-regions-evidence-tracker/">Grassrivers, Port Gellhorn, Ambrosia, and Mount Kalaga overview</a></li>
      </ul>
    </div>
  </section>
</BaseLayout>

