---
import BaseLayout from "@layouts/BaseLayout.astro";
import ConfidenceBadge from "@components/ConfidenceBadge.astro";

const regions = [
  ["Vice City", "Miami-inspired urban core", "official"],
  ["Leonida Keys", "Island and coastal region", "official"],
  ["Grassrivers", "Wetlands region", "official"],
  ["Port Gellhorn", "Coastal destination", "official"],
  ["Ambrosia", "Industrial/community region", "official"],
  ["Mount Kalaga", "Northern/wildland destination", "official"]
] as const;
---

<BaseLayout title="GTA 6 Map and Leonida Locations" description="Official GTA 6 locations across Leonida, including Vice City, Leonida Keys, Grassrivers, Port Gellhorn, Ambrosia, and Mount Kalaga." image="/assets/og-map.png">
  <header class="page-header shell">
    <div class="page-kicker">Map intel</div>
    <h1 class="page-title">GTA 6 Map and Leonida Locations</h1>
    <p class="page-intro">
      Rockstar has named six Leonida destinations. Use the region board and location guides below for the currently confirmed map information.
    </p>
  </header>

  <section class="section-tight shell split">
    <div class="panel">
      <h2>Official Region Board</h2>
      <table class="database-table">
        <thead>
          <tr>
            <th>Region</th>
            <th>Role</th>
            <th>Confidence</th>
          </tr>
        </thead>
        <tbody>
          {regions.map(([name, role, confidence]) => (
            <tr>
              <td><strong>{name}</strong></td>
              <td>{role}</td>
              <td><ConfidenceBadge value={confidence} /></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="panel">
      <h2>Location Guides</h2>
      <ul>
        <li><a href="/guides/gta-6-vice-city-location-guide/">Vice City</a></li>
        <li><a href="/guides/gta-6-leonida-keys-location-guide/">Leonida Keys</a></li>
        <li><a href="/guides/gta-6-grassrivers-location-guide/">Grassrivers</a></li>
        <li><a href="/guides/gta-6-port-gellhorn-location-guide/">Port Gellhorn</a></li>
        <li><a href="/guides/gta-6-map-leonida-regions-evidence-tracker/">Ambrosia and Mount Kalaga overview</a></li>
      </ul>
    </div>
  </section>
</BaseLayout>

