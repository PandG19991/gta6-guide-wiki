---
import BaseLayout from "@layouts/BaseLayout.astro";
import GuideCard from "@components/GuideCard.astro";
import { publicGuideCategoryMeta, publicGuides } from "@data/guides";
import { site } from "@data/site";

const description = "Browse GTA 6 release, buying, map, character, vehicle, platform, and spoiler-prevention guides.";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "GTA 6 Guides",
    url: `${site.url}/guides/`,
    description,
    mainEntity: {
      "@type": "ItemList",
      itemListElement: publicGuides.map((guide, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: guide.title,
        url: `${site.url}/guides/${guide.slug}/`
      }))
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url },
      { "@type": "ListItem", position: 2, name: "Guides", item: `${site.url}/guides/` }
    ]
  }
];
---

<BaseLayout title="GTA 6 Guides" description={description} schema={schema}>
  <header class="page-header shell">
    <h1 class="page-title">GTA 6 Guides</h1>
    <p class="page-intro">
      Browse current GTA 6 answers by topic, from release and buying decisions to maps, characters, and vehicles.
    </p>
  </header>

  <section class="section-tight shell">
    <nav class="category-strip" aria-label="Guide categories">
      {publicGuideCategoryMeta.map((meta) => (
        <a href={`/guides/category/${meta.slug}/`}>{meta.category}</a>
      ))}
    </nav>
    <form class="toolbar" data-guide-filters>
      <input class="field" type="search" name="q" placeholder="Search guides, locations, vehicles, and more..." aria-label="Search guides" />
      <select class="field" name="category" aria-label="Filter by guide topic">
        <option value="all">All topics</option>
        {publicGuideCategoryMeta.map((meta) => <option value={meta.category}>{meta.category}</option>)}
      </select>
    </form>
    <div class="guide-list">
      {publicGuides.map((guide) => <GuideCard guide={guide} />)}
    </div>
  </section>

  <script>
    const form = document.querySelector("[data-guide-filters]");
    const cards = Array.from(document.querySelectorAll("[data-guide-card]"));
    const applyFilters = () => {
      if (!form) return;
      const data = new FormData(form as HTMLFormElement);
      const query = String(data.get("q") || "").trim().toLowerCase();
      const category = String(data.get("category") || "all");
      cards.forEach((card) => {
        const el = card as HTMLElement;
        const text = el.getAttribute("data-search") || "";
        const matchesQuery = !query || text.includes(query);
        const matchesCategory = category === "all" || el.getAttribute("data-category") === category;
        el.hidden = !(matchesQuery && matchesCategory);
      });
    };
    const params = new URLSearchParams(window.location.search);
    const q = params.get("q");
    if (q && form) {
      const field = form.querySelector('input[name="q"]') as HTMLInputElement | null;
      if (field) field.value = q;
    }
    form?.addEventListener("input", applyFilters);
    applyFilters();
  </script>
</BaseLayout>

