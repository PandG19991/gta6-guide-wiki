---
import BaseLayout from "@layouts/BaseLayout.astro";
import GuideCard from "@components/GuideCard.astro";
import { publicGuideCategoryMeta, publicGuides } from "@data/guides";
import { confidenceLevels, site } from "@data/site";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "GTA 6 Guides",
    url: `${site.url}/guides/`,
    description: "All Leonida Ledger GTA 6 guides, trackers, launch-week pages, and evergreen database plans.",
    mainEntity: {
      "@type": "ItemList",
      itemListElement: publicGuides.map((guide, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: guide.title,
        url: `${site.url}/guides/${guide.slug}/`
      }))
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url },
      { "@type": "ListItem", position: 2, name: "Guides", item: `${site.url}/guides/` }
    ]
  }
];
---

<BaseLayout title="GTA 6 Guides" description="All Leonida Ledger GTA 6 guides, trackers, launch-week pages, and evergreen database plans." schema={schema}>
  <header class="page-header shell">
    <div class="page-kicker">Guide index</div>
    <h1 class="page-title">GTA 6 Guides</h1>
    <p class="page-intro">
      Search-intent pages grouped by what players need now and what will become tested launch-week walkthroughs later.
    </p>
  </header>

  <section class="section-tight shell">
    <nav class="category-strip" aria-label="Guide categories">
      {publicGuideCategoryMeta.map((meta) => (
        <a href={`/guides/category/${meta.slug}/`}>{meta.category}</a>
      ))}
    </nav>
    <form class="toolbar" data-guide-filters>
      <input class="field" type="search" name="q" placeholder="Search guides, locations, vehicles, and more..." aria-label="Search guides" />
      <select class="field" name="intent" aria-label="Filter by search phase">
        <option value="all">Topic: All</option>
        <option value="pre-launch">Pre-launch</option>
        <option value="launch-week">Launch week</option>
        <option value="evergreen">Evergreen</option>
      </select>
      <select class="field" name="confidence" aria-label="Filter by confidence">
        <option value="all">Confidence: Any</option>
        {confidenceLevels.map((level) => <option value={level.key}>{level.label}</option>)}
      </select>
    </form>
    <div class="guide-list">
      {publicGuides.map((guide) => <GuideCard guide={guide} />)}
    </div>
  </section>

  <script>
    const form = document.querySelector("[data-guide-filters]");
    const cards = Array.from(document.querySelectorAll("[data-guide-card]"));
    const applyFilters = () => {
      if (!form) return;
      const data = new FormData(form as HTMLFormElement);
      const query = String(data.get("q") || "").trim().toLowerCase();
      const intent = String(data.get("intent") || "all");
      const confidence = String(data.get("confidence") || "all");
      cards.forEach((card) => {
        const el = card as HTMLElement;
        const text = el.getAttribute("data-search") || "";
        const matchesQuery = !query || text.includes(query);
        const matchesIntent = intent === "all" || el.getAttribute("data-intent") === intent;
        const matchesConfidence = confidence === "all" || el.getAttribute("data-confidence") === confidence;
        el.hidden = !(matchesQuery && matchesIntent && matchesConfidence);
      });
    };
    const params = new URLSearchParams(window.location.search);
    const q = params.get("q");
    if (q && form) {
      const field = form.querySelector('input[name="q"]') as HTMLInputElement | null;
      if (field) field.value = q;
    }
    form?.addEventListener("input", applyFilters);
    applyFilters();
  </script>
</BaseLayout>

