---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getImage } from "astro:assets";
import GuideMedia from "@components/GuideMedia.astro";
import { guideArticles } from "@data/guideArticles";
import { categoryMetaByName, publicGuides } from "@data/guides";
import { mediaById } from "@data/media";
import { sourceById } from "@data/sources";
import { site } from "@data/site";

export function getStaticPaths() {
  return publicGuides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide }
  }));
}

const { guide } = Astro.props;
const primaryMedia = guide.primaryMediaId ? mediaById[guide.primaryMediaId] : undefined;
const socialImage = primaryMedia
  ? await getImage({ src: primaryMedia.local, width: 1200, height: 675, format: "jpg", quality: 82 })
  : undefined;
const image = socialImage?.src;
const relatedGuides = publicGuides
  .filter((candidate) => candidate.slug !== guide.slug && candidate.category === guide.category)
  .slice(0, 3);
const firstAnswer = guide.bullets[0];
const decisionRows = guide.decisionRows ?? [];
const guideSections = guideArticles[guide.slug] ?? [];
const evidenceLabel = {
  official: "Official sources",
  "first-party-tested": "Tested by Leonida Ledger",
  corroborated: "Editor-verified sources"
}[guide.evidence];
const playerSourceIds = new Set([
  "rockstar-vi",
  "rockstar-preorders",
  "take-two-preorders",
  "rockstar-leonida",
  "rockstar-media",
  "rockstar-editions",
  "rockstar-support-editions",
  "rockstar-support-preorders"
]);
const guideSources = guide.sourceIds.map((id) => sourceById[id]).filter((source) => source && playerSourceIds.has(source.id));
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: guide.title,
    description: guide.deck,
    ...(image ? { image: new URL(image, site.url).toString() } : {}),
    inLanguage: "en-US",
    datePublished: guide.updated,
    dateModified: guide.updated,
    author: { "@type": "Organization", name: "Leonida Ledger Editorial Team" },
    reviewedBy: { "@type": "Organization", name: "Leonida Ledger Editorial Team" },
    publisher: { "@type": "Organization", name: site.name },
    mainEntityOfPage: `${site.url}/guides/${guide.slug}/`
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url },
      { "@type": "ListItem", position: 2, name: "Guides", item: `${site.url}/guides/` },
      { "@type": "ListItem", position: 3, name: guide.title, item: `${site.url}/guides/${guide.slug}/` }
    ]
  }
];
---

<BaseLayout
  title={guide.title}
  description={guide.deck}
  image={image}
  imageAlt={primaryMedia?.alt}
  imageWidth={1200}
  imageHeight={675}
  ogType="article"
  schema={schema}
>
  <header class="article-header shell">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span><a href="/guides/">Guides</a><span>/</span><a href={`/guides/category/${categoryMetaByName[guide.category].slug}/`}>{guide.category}</a>
    </nav>
    <h1>{guide.title}</h1>
    <p>{guide.deck}</p>
    <div class="article-meta">
      <span>{guide.category}</span>
      <time datetime={guide.updated}>Updated {guide.updated}</time>
      <span class="meta-copy">Reviewed by Leonida Ledger Editorial Team</span>
    </div>
    <p class="article-applicability">Applies to {guide.platforms.join(", ")} - {guide.gameVersion} - {evidenceLabel}</p>
    {guide.evidence === "first-party-tested" && guide.tested && (
      <p class="article-test-details">
        Tested on {guide.tested.platform}, version {guide.tested.gameVersion}, {guide.tested.testedAt}. Method: {guide.tested.method}
      </p>
    )}
    {guide.spoilerLevel && (
      <p class={`spoiler-warning ${guide.spoilerLevel}`}>
        {guide.spoilerLevel === "story" ? "Story detail warning: this guide discusses official promotional story material." : "Gameplay spoiler warning: this guide describes gameplay details."}
      </p>
    )}
  </header>

  <div class="article-layout shell">
    <article class="article-main">
      <div class={`article-lead${primaryMedia ? " has-media" : ""}`}>
        <section class="quick-answer" id="quick-answer">
          <strong>Quick answer</strong>
          <p>{firstAnswer}</p>
        </section>
        {guide.primaryMediaId && (
          <GuideMedia id={guide.primaryMediaId} priority attribution sizes="(max-width: 850px) 100vw, 520px" />
        )}
      </div>

      <section class="article-section" id="key-points">
        <h2>What To Know</h2>
        <ul class="key-points">
          {guide.bullets.slice(1).map((bullet) => <li>{bullet}</li>)}
        </ul>
      </section>

      {guideSections.map((section) => (
        <section class="article-section guide-detail-section" id={section.id}>
          <h2>{section.title}</h2>
          {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          {section.points && (
            <ul class="key-points detail-points">
              {section.points.map((point) => <li>{point}</li>)}
            </ul>
          )}
        </section>
      ))}

      {decisionRows.length > 0 && (
        <section class="article-section" id="decision-table">
          <h2>Decision Table</h2>
          <div class="table-scroll">
            <table class="source-table decision-table">
              <thead><tr><th>Option</th><th>Best for</th><th>Current status</th><th>Caveat</th></tr></thead>
              <tbody>
                {decisionRows.map((row) => (
                  <tr><td><strong>{row.option}</strong></td><td>{row.bestFor}</td><td>{row.status}</td><td>{row.caveat}</td></tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )}

      <section class="article-section next-action" id="next-action">
        <strong>Next step</strong>
        <h2><a href={guide.nextAction.href}>{guide.nextAction.label}</a></h2>
      </section>

      <section class="article-section" id="sources">
        <h2>Sources</h2>
        <div class="source-list compact-sources">
          {guideSources.map((source) => (
            <p><a href={source.url} target="_blank" rel="noopener">{source.title}</a><span>{source.publisher} - Accessed {source.accessed}</span></p>
          ))}
        </div>
      </section>

      {relatedGuides.length > 0 && (
        <section class="article-section" id="related-guides">
          <h2>More In {guide.category}</h2>
          <div class="related-guide-list">
            {relatedGuides.map((item) => (
              <a href={`/guides/${item.slug}/`}>
                {item.primaryMediaId && <GuideMedia id={item.primaryMediaId} sizes="140px" />}
                <span><small>{item.category}</small><strong>{item.title}</strong></span><b aria-hidden="true">&gt;</b>
              </a>
            ))}
          </div>
        </section>
      )}
    </article>

    <aside class="article-rail">
      <nav aria-label="On this page">
        <strong>On This Page</strong>
        <a href="#quick-answer">Quick answer</a>
        <a href="#key-points">What to know</a>
        {guideSections.map((section) => <a href={`#${section.id}`}>{section.title}</a>)}
        {decisionRows.length > 0 && <a href="#decision-table">Decision table</a>}
        <a href="#next-action">Next step</a>
        <a href="#sources">Sources</a>
      </nav>
    </aside>
  </div>
</BaseLayout>
