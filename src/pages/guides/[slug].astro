---
import BaseLayout from "@layouts/BaseLayout.astro";
import ConfidenceBadge from "@components/ConfidenceBadge.astro";
import Gta6Rail from "@components/Gta6Rail.astro";
import { categoryMetaByName, publicGuides } from "@data/guides";
import { sourceById } from "@data/sources";
import { site } from "@data/site";

export function getStaticPaths() {
  return publicGuides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide }
  }));
}

const { guide } = Astro.props;
const image = categoryMetaByName[guide.category].image;
const relatedGuides = publicGuides
  .filter((candidate) => candidate.slug !== guide.slug && candidate.category === guide.category)
  .slice(0, 3);
const firstAnswer = guide.bullets[0];
const decisionRows = guide.decisionRows ?? [];
const playerSourceIds = new Set(["rockstar-vi", "rockstar-preorders", "take-two-preorders", "rockstar-leonida", "rockstar-media"]);
const guideSources = guide.sourceIds.map((id) => sourceById[id]).filter((source) => source && playerSourceIds.has(source.id));
const faqItems = [
  {
    question: `What is the short answer for ${guide.title}?`,
    answer: guide.bullets[0]
  },
  {
    question: `What else should players know about ${guide.title}?`,
    answer: guide.bullets[1] ?? guide.bullets[0]
  },
  {
    question: `What should players check before acting on this ${guide.category.toLowerCase()} guide?`,
    answer: guide.bullets[2] ?? guide.bullets.at(-1) ?? guide.bullets[0]
  }
];
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: guide.title,
    description: guide.deck,
    image: new URL(image, site.url).toString(),
    inLanguage: "en-US",
    datePublished: guide.updated,
    dateModified: guide.updated,
    author: { "@type": "Organization", name: site.name },
    publisher: { "@type": "Organization", name: site.name },
    mainEntityOfPage: `${site.url}/guides/${guide.slug}/`
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url },
      { "@type": "ListItem", position: 2, name: "Guides", item: `${site.url}/guides/` },
      { "@type": "ListItem", position: 3, name: guide.title, item: `${site.url}/guides/${guide.slug}/` }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer
      }
    }))
  }
];
---

<BaseLayout title={guide.title} description={guide.deck} image={image} schema={schema}>
  <header class="page-header shell">
    <div class="page-kicker">{guide.category}</div>
    <h1 class="page-title">{guide.title}</h1>
    <p class="page-intro">{guide.deck}</p>
  </header>

  <Gta6Rail />

  <section class="section-tight shell">
    <div class="snapshot-grid" aria-label="Answer snapshot">
      <article class="snapshot-card primary">
        <strong class="meta-label">Short answer</strong>
        <p>{firstAnswer}</p>
      </article>
      <article class="snapshot-card">
        <strong class="meta-label">Confidence</strong>
        <p><ConfidenceBadge value={guide.confidence} /></p>
      </article>
      <article class="snapshot-card">
        <strong class="meta-label">Last updated</strong>
        <p class="mono">{guide.updated}</p>
      </article>
    </div>
  </section>

  {relatedGuides.length > 0 && (
    <section class="shell next-clicks" aria-label="Related next clicks">
      {relatedGuides.map((item) => (
        <a href={`/guides/${item.slug}/`}>
          <span>{item.category}</span>
          <strong>{item.title}</strong>
        </a>
      ))}
    </section>
  )}

  <section class="section-tight shell">
    <article class="panel">
      <h2>What To Know</h2>
      <ul>
        {guide.bullets.map((bullet) => <li>{bullet}</li>)}
      </ul>
    </article>
  </section>

  {decisionRows.length > 0 && (
    <section class="section-tight shell">
      <h2 class="page-title">Decision Table</h2>
      <table class="source-table decision-table">
        <thead>
          <tr>
            <th>Option</th>
            <th>Best for</th>
            <th>Current status</th>
            <th>Caveat</th>
          </tr>
        </thead>
        <tbody>
          {decisionRows.map((row) => (
            <tr>
              <td><strong>{row.option}</strong></td>
              <td>{row.bestFor}</td>
              <td>{row.status}</td>
              <td>{row.caveat}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  <section class="section-tight shell">
    <h2 class="page-title">Sources</h2>
    <div class="source-list">
      {guideSources.map((source) => (
        <p>
          <a href={source.url} target="_blank" rel="nofollow noopener">{source.title}</a>
          <br />{source.publisher}. Accessed {source.accessed}.
        </p>
      ))}
    </div>
  </section>

  <section class="section-tight shell">
    <h2 class="page-title">Quick FAQ</h2>
    <div class="faq-list">
      {faqItems.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </section>

  {relatedGuides.length > 0 && (
    <section class="section-tight shell">
      <h2 class="page-title">Related Guides</h2>
      <div class="content-grid">
        {relatedGuides.map((item) => (
          <article class="content-card">
            <div class="card-meta"><ConfidenceBadge value={item.confidence} /></div>
            <h3><a href={`/guides/${item.slug}/`}>{item.title}</a></h3>
            <p>{item.deck}</p>
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

