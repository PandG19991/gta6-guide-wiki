---
import BaseLayout from "@layouts/BaseLayout.astro";
import ConfidenceBadge from "@components/ConfidenceBadge.astro";
import { categoryMetaByName, guides } from "@data/guides";
import { sourceById } from "@data/sources";
import { site } from "@data/site";

export function getStaticPaths() {
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide }
  }));
}

const { guide } = Astro.props;
const image = categoryMetaByName[guide.category].image;
const relatedGuides = guides
  .filter((candidate) => candidate.slug !== guide.slug && candidate.category === guide.category)
  .slice(0, 3);
const firstAnswer = guide.bullets[0];
const decisionRows = guide.decisionRows ?? [];
const verificationPlan = [
  {
    label: "Current proof",
    value: `${guide.sourceIds.length} source${guide.sourceIds.length === 1 ? "" : "s"} / ${guide.confidence} confidence`
  },
  {
    label: "Search phase",
    value: `${guide.intent} / ${guide.status}`
  },
  {
    label: "Update trigger",
    value: guide.nextUpdate
  }
];
const faqItems = [
  {
    question: `What is the short answer for ${guide.title}?`,
    answer: guide.bullets[0]
  },
  {
    question: `How reliable is this ${guide.category.toLowerCase()} page?`,
    answer: `This page is marked ${guide.confidence}. It does not treat rumors, leaks, or untested launch-week details as confirmed facts.`
  },
  {
    question: `When will this ${guide.category.toLowerCase()} guide be updated?`,
    answer: guide.nextUpdate
  }
];
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: guide.title,
    description: guide.deck,
    datePublished: guide.updated,
    dateModified: guide.updated,
    author: { "@type": "Organization", name: site.name },
    publisher: { "@type": "Organization", name: site.name },
    mainEntityOfPage: `${site.url}/guides/${guide.slug}/`
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url },
      { "@type": "ListItem", position: 2, name: "Guides", item: `${site.url}/guides/` },
      { "@type": "ListItem", position: 3, name: guide.title, item: `${site.url}/guides/${guide.slug}/` }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer
      }
    }))
  }
];
---

<BaseLayout title={guide.title} description={guide.deck} image={image} schema={schema}>
  <header class="page-header shell">
    <div class="page-kicker">{guide.category} / {guide.intent}</div>
    <h1 class="page-title">{guide.title}</h1>
    <p class="page-intro">{guide.deck}</p>
  </header>

  <section class="section-tight shell">
    <div class="snapshot-grid" aria-label="Answer snapshot">
      <article class="snapshot-card primary">
        <strong class="meta-label">Short answer</strong>
        <p>{firstAnswer}</p>
      </article>
      <article class="snapshot-card">
        <strong class="meta-label">Confidence</strong>
        <p><ConfidenceBadge value={guide.confidence} /></p>
      </article>
      <article class="snapshot-card">
        <strong class="meta-label">Last updated</strong>
        <p class="mono">{guide.updated}</p>
      </article>
      <article class="snapshot-card">
        <strong class="meta-label">Source count</strong>
        <p>{guide.sourceIds.length}</p>
      </article>
    </div>
  </section>

  <section class="section-tight shell split">
    <article class="panel">
      <h2>Current Answer</h2>
      <p><ConfidenceBadge value={guide.confidence} /> <span class="mono">Updated {guide.updated}</span></p>
      <ul>
        {guide.bullets.map((bullet) => <li>{bullet}</li>)}
      </ul>
      <h3>Next Update</h3>
      <p>{guide.nextUpdate}</p>
    </article>
    <aside class="panel">
      <h2>Search Terms Covered</h2>
      <p>{guide.searchTerms.join(" / ")}</p>
      <h3>Page Status</h3>
      <p>
        This page is marked <strong>{guide.status}</strong>. If a fact is not official or tested, it is not written as confirmed.
      </p>
    </aside>
  </section>

  {decisionRows.length > 0 && (
    <section class="section-tight shell">
      <h2 class="page-title">Decision Table</h2>
      <table class="source-table decision-table">
        <thead>
          <tr>
            <th>Option</th>
            <th>Best for</th>
            <th>Current status</th>
            <th>Caveat</th>
          </tr>
        </thead>
        <tbody>
          {decisionRows.map((row) => (
            <tr>
              <td><strong>{row.option}</strong></td>
              <td>{row.bestFor}</td>
              <td>{row.status}</td>
              <td>{row.caveat}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  <section class="section-tight shell">
    <h2 class="page-title">Source Ledger</h2>
    <div class="source-list">
      {guide.sourceIds.map((id) => {
        const source = sourceById[id];
        return (
          <p>
            <a href={source.url} target="_blank" rel="nofollow noopener">{source.title}</a>
            <br />
            {source.publisher}. Accessed {source.accessed}. {source.notes}
          </p>
        );
      })}
    </div>
  </section>

  <section class="section-tight shell">
    <h2 class="page-title">Verification Plan</h2>
    <div class="source-list">
      {verificationPlan.map((item) => (
        <p>
          <strong>{item.label}</strong>
          <br />
          {item.value}
        </p>
      ))}
    </div>
  </section>

  <section class="section-tight shell">
    <h2 class="page-title">Quick FAQ</h2>
    <div class="faq-list">
      {faqItems.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </section>

  {relatedGuides.length > 0 && (
    <section class="section-tight shell">
      <h2 class="page-title">Related Guides</h2>
      <div class="content-grid">
        {relatedGuides.map((item) => (
          <article class="content-card">
            <div class="card-meta"><ConfidenceBadge value={item.confidence} /></div>
            <h3><a href={`/guides/${item.slug}/`}>{item.title}</a></h3>
            <p>{item.deck}</p>
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

