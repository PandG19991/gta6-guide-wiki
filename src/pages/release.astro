---
import BaseLayout from "@layouts/BaseLayout.astro";
import GuideMedia from "@components/GuideMedia.astro";
import { site } from "@data/site";
import { sourceById } from "@data/sources";

const facts = [
  ["Release date", "November 19, 2026"],
  ["Platforms", "PlayStation 5 and Xbox Series X|S"],
  ["Standard price", "$79.99"],
  ["Ultimate Edition price", "$99.99"],
  ["Digital preload", "November 12, 2026 at 12:00 a.m. for the applicable PlayStation or Xbox store region"],
  ["Physical format", "Download code in box; no disc"],
  ["PC release date", "Not officially announced"]
] as const;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: "GTA 6 Release Date, Countdown, and Preload Times",
    dateModified: site.currentDate,
    author: { "@type": "Organization", name: site.name },
    image: new URL("/assets/og-release.png", site.url).toString(),
    inLanguage: "en-US",
    mainEntityOfPage: `${site.url}/release/`
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url },
      { "@type": "ListItem", position: 2, name: "Release", item: `${site.url}/release/` }
    ]
  }
];
---

<BaseLayout title="GTA 6 Release Date and Preload Guide" description="Official GTA 6 release date, platforms, preload timing, pricing, and preorder status with source links." image="/assets/og-release.png" schema={schema}>
  <header class="page-header shell">
    <h1 class="page-title">GTA 6 Release Date and Preload Guide</h1>
    <p class="page-intro">
      Fast answer: Grand Theft Auto VI is officially scheduled for November 19, 2026 on PS5 and Xbox Series X|S.
      Digital preloading is currently scheduled for November 12, 2026. PC timing remains unannounced.
    </p>
  </header>

  <section class="section-tight shell">
    <GuideMedia id="cover-art" priority sizes="(max-width: 900px) 100vw, 900px" />
  </section>

  <section class="section-tight shell split">
    <div class="panel">
      <h2>Launch Facts</h2>
      <table class="database-table">
        <tbody>
          {facts.map(([label, value]) => (
            <tr>
              <th>{label}</th>
              <td>{value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="panel">
      <h2>What To Watch Next</h2>
      <ul>
        <li>Store page updates for preload timing by region.</li>
        <li>Any official PC, performance, or PS5 Pro feature statement.</li>
        <li>Retailer language for boxed versions that include download codes.</li>
      </ul>
    </div>
  </section>

  <section class="section-tight shell">
    <h2 class="page-title">Primary Sources</h2>
    <div class="source-list">
      {["rockstar-vi", "take-two-preorders", "rockstar-preorders"].map((id) => {
        const source = sourceById[id];
        return (
          <p>
            <a href={source.url} rel="noopener" target="_blank">{source.title}</a>
            <br />
            {source.publisher}: {source.notes}
          </p>
        );
      })}
    </div>
  </section>
</BaseLayout>

