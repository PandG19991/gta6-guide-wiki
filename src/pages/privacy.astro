---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Policy" description="Leonida Ledger privacy policy for the GTA 6 guide site, including current data use, contact links, and future ads or analytics notes.">
  <header class="page-header shell">
    <div class="page-kicker">Privacy</div>
    <h1 class="page-title">Privacy Policy</h1>
    <p class="page-intro">
      This first release does not collect accounts, payments, comments, or personal profiles. Future analytics or ads will be documented here before use.
    </p>
  </header>

  <section class="section-tight shell split">
    <div class="panel">
      <h2>Current Data Use</h2>
      <ul>
        <li>No login system.</li>
        <li>No first-party tracking cookies in this release.</li>
        <li>No user-submitted personal data forms beyond a plain contact email link.</li>
      </ul>
    </div>
    <div class="panel">
      <h2>Future Ads And Analytics</h2>
      <p>
        If Google AdSense, analytics, or consent tooling is added later, this page must be updated before production use.
      </p>
    </div>
  </section>
</BaseLayout>

