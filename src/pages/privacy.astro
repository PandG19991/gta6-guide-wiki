---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Policy" description="Leonida Ledger privacy policy covering current site data use, advertising, analytics, and contact links.">
  <header class="page-header shell">
    <div class="page-kicker">Privacy</div>
    <h1 class="page-title">Privacy Policy</h1>
    <p class="page-intro">
      Leonida Ledger currently has no accounts, payments, comments, advertising scripts, or first-party analytics.
    </p>
  </header>

  <section class="section-tight shell split">
    <div class="panel">
      <h2>Current Data Use</h2>
      <ul>
        <li>No login system.</li>
        <li>No first-party tracking cookies in this release.</li>
        <li>No user-submitted personal data forms beyond a plain contact email link.</li>
      </ul>
    </div>
    <div class="panel">
      <h2>Advertising And Analytics</h2>
      <p>
        No advertising or analytics service is active today. This policy and any required consent controls will be updated before those services are enabled.
      </p>
    </div>
  </section>
</BaseLayout>

