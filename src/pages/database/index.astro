---
import BaseLayout from "@layouts/BaseLayout.astro";
import { site } from "@data/site";
---

<BaseLayout
  title="GTA 6 Database Entry"
  description="Legacy database entry for Leonida Ledger. The current GTA 6 database hub now lives under the GTA 6 section."
  canonical={`${site.url}/gta-6/database/`}
>
  <header class="page-header shell">
    <div class="page-kicker">Database moved</div>
    <h1 class="page-title">GTA 6 Database</h1>
    <p class="page-intro">
      The current database hub is now organized under the GTA 6 section so the content tree matches player search paths.
    </p>
    <div class="section-actions">
      <a class="button" href="/gta-6/database/">Open the GTA 6 database</a>
    </div>
  </header>
</BaseLayout>
