---
import BaseLayout from "@layouts/BaseLayout.astro";
import ConfidenceBadge from "@components/ConfidenceBadge.astro";
import { databaseSections } from "@data/database";
---

<BaseLayout title="GTA 6 Database" description="Structured GTA 6 database hub for people, places, vehicles, missions, cheats, and evidence status.">
  <header class="page-header shell">
    <div class="page-kicker">Database</div>
    <h1 class="page-title">GTA 6 Database</h1>
    <p class="page-intro">
      The database exists to support useful guide pages and internal links. Empty categories stay empty until official or tested data exists.
    </p>
  </header>

  <section class="section-tight shell">
    <div class="content-grid">
      {databaseSections.map((section) => (
        <article class="content-card">
          <div class="card-meta">
            <ConfidenceBadge value={section.confidence} />
            <span class="badge unconfirmed">{section.count} records</span>
          </div>
          <h3>{section.title}</h3>
          <p><strong>Fields:</strong> {section.fields.join(", ")}</p>
          <p>{section.records.length ? section.records.join(" / ") : "No public records yet. This category opens after official or hands-on verification."}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

