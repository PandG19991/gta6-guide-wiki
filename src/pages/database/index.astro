---
import BaseLayout from "@layouts/BaseLayout.astro";
import { site } from "@data/site";
---

<BaseLayout
  title="Open the GTA 6 Database"
  description="Open the main GTA 6 database for confirmed vehicles, characters, locations, and editions."
  canonical={`${site.url}/gta-6/database/`}
  robots="noindex,follow,max-image-preview:large"
>
  <header class="page-header shell">
    <div class="page-kicker">GTA 6 database</div>
    <h1 class="page-title">GTA 6 Database</h1>
    <p class="page-intro">
      Browse confirmed GTA 6 vehicles, characters, locations, and editions in the main database.
    </p>
    <div class="section-actions">
      <a class="button" href="/gta-6/database/">Open the GTA 6 database</a>
    </div>
  </header>
</BaseLayout>
