---
import BaseLayout from "@layouts/BaseLayout.astro";
import { confidenceLevels } from "@data/site";
---

<BaseLayout title="Editorial Policy" description="How Leonida Ledger handles official GTA 6 sources, rumors, corrections, copyright, and independent coverage.">
  <header class="page-header shell">
    <div class="page-kicker">Editorial policy</div>
    <h1 class="page-title">Editorial Policy</h1>
    <p class="page-intro">
      Leonida Ledger separates official information, direct observations, analysis, and unconfirmed claims so players can see what is known.
    </p>
  </header>

  <section class="section-tight shell split">
    <div class="panel">
      <h2>Source Hierarchy</h2>
      {confidenceLevels.map((level) => (
        <p><strong>{level.label}:</strong> {level.description}</p>
      ))}
    </div>
    <div class="panel">
      <h2>Corrections And Rights</h2>
      <ul>
        <li>Official Rockstar, Take-Two, and platform-store information takes priority.</li>
        <li>Rumors and leaks are not presented as confirmed facts.</li>
        <li>We do not host leaked footage, leaked maps, copied guides, or rehosted media packs.</li>
        <li>Correction and rights requests can be sent through the <a href="/contact/">contact page</a>.</li>
      </ul>
      <p><a href="/sources/">View GTA 6 sources and correction details.</a></p>
    </div>
  </section>
</BaseLayout>

