---
import BaseLayout from "@layouts/BaseLayout.astro";
import { site } from "@data/site";

const testTemplates = [
  {
    type: "Mission walkthrough",
    record: "Platform, mission name, objective order, fail states, reward, replay notes.",
    publishWhen: "The route is completed in-game and the reward/outcome is repeatable.",
    doNotPublish: "Rumored mission order, leaked scripts, or spoiler claims without hands-on proof."
  },
  {
    type: "Cheat code",
    record: "Platform, input method, exact code, effect, limits, save/trophy side effects.",
    publishWhen: "The same code works twice on the same platform or is official.",
    doNotPublish: "Fake unlimited-money codes, malware bait, or online-cheating instructions."
  },
  {
    type: "Vehicle guide",
    record: "Class, location or store, price, storage, upgrades, handling notes.",
    publishWhen: "The vehicle is official, visible in a source, or found in released gameplay.",
    doNotPublish: "Leak-list names without a source or copied screenshots."
  },
  {
    type: "Map marker",
    record: "Region, marker name, coordinates or nearby landmark, proof source, confidence.",
    publishWhen: "The marker is official or verified from released gameplay.",
    doNotPublish: "Leaked map grids, fan guesses presented as fact, or copyrighted map uploads."
  },
  {
    type: "Money method",
    record: "Prerequisites, time cost, payout, risk, platform, repeatability.",
    publishWhen: "The method is repeatable and does not rely on exploits or cheating.",
    doNotPublish: "Generators, glitches, account services, or claims that encourage abuse."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "Leonida Ledger Testing Protocol",
  url: `${site.url}/testing-protocol/`,
  description: "Launch-week verification templates for Leonida Ledger GTA 6 guides.",
  mainEntity: {
    "@type": "ItemList",
    itemListElement: testTemplates.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.type,
      description: item.record
    }))
  }
};
---

<BaseLayout
  title="Testing Protocol"
  description="How Leonida Ledger will verify GTA 6 missions, cheats, vehicles, map markers, and money guides after launch."
  schema={schema}
>
  <header class="page-header shell">
    <div class="page-kicker">Launch-week verification</div>
    <h1 class="page-title">Testing Protocol</h1>
    <p class="page-intro">
      These templates define what must be checked before a launch-week guide can move from planning notes to a published answer.
    </p>
  </header>

  <section class="section-tight shell split">
    <div class="panel">
      <h2>Publish Standard</h2>
      <ul>
        <li>Every tested claim names the platform, source type, and confidence level.</li>
        <li>Repeatable mechanics need at least two matching checks or an official source.</li>
        <li>Spoilers stay out of basic setup pages unless the page title clearly warns the reader.</li>
        <li>Pages can stay live as planning URLs, but untested mechanics remain labeled as launch-week.</li>
      </ul>
    </div>
    <div class="panel">
      <h2>Reject Standard</h2>
      <ul>
        <li>No leaked maps, prerelease footage, copied screenshots, or copied guide text.</li>
        <li>No fake cheat codes, money generators, account services, or online cheating steps.</li>
        <li>No exact prices, file sizes, mission rewards, or spawn claims without a stable source.</li>
        <li>No thin page whose only job is to catch a keyword and show ads.</li>
      </ul>
    </div>
  </section>

  <section class="section-tight shell">
    <h2 class="page-title">Test Templates</h2>
    <table class="source-table decision-table">
      <thead>
        <tr>
          <th>Guide type</th>
          <th>Record</th>
          <th>Publish when</th>
          <th>Do not publish</th>
        </tr>
      </thead>
      <tbody>
        {testTemplates.map((item) => (
          <tr>
            <td><strong>{item.type}</strong></td>
            <td>{item.record}</td>
            <td>{item.publishWhen}</td>
            <td>{item.doNotPublish}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</BaseLayout>
