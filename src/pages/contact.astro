---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Report An Error" description="Report an incorrect GTA 6 fact, broken link, or image concern to Leonida Ledger.">
  <header class="page-header shell">
    <div class="page-kicker">Contact</div>
    <h1 class="page-title">Report An Error</h1>
    <p class="page-intro">
      Found an incorrect fact, broken link, or image concern? Tell us which page needs attention and what should be corrected.
    </p>
  </header>

  <section class="section-tight shell">
    <div class="panel">
      <h2>Send A Correction</h2>
      <p>Include the page URL, the incorrect detail, and a supporting link when available.</p>
      <p><a class="button secondary" href="https://github.com/PandG19991/gta6-guide-wiki/issues" target="_blank" rel="noopener">Report an issue</a></p>
    </div>
  </section>
</BaseLayout>

