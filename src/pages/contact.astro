---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" description="Contact Leonida Ledger for corrections, source updates, and rights concerns.">
  <header class="page-header shell">
    <div class="page-kicker">Contact</div>
    <h1 class="page-title">Corrections And Rights Contact</h1>
    <p class="page-intro">
      For factual corrections, source updates, or rights concerns, use the project repository issue tracker after GitHub publication.
      Do not send leaked footage or copyrighted asset packs.
    </p>
  </header>

  <section class="section-tight shell">
    <div class="panel">
      <h2>Submission Rules</h2>
      <ul>
        <li>Send source URLs and what changed.</li>
        <li>Mark whether the claim is official, observed, analysis, or unconfirmed.</li>
        <li>Do not submit leaked pre-release material or copyrighted media for hosting.</li>
      </ul>
    </div>
  </section>
</BaseLayout>

