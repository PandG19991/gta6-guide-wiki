---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" description="Contact Leonida Ledger for corrections, source updates, and rights concerns.">
  <header class="page-header shell">
    <div class="page-kicker">Contact</div>
    <h1 class="page-title">Corrections And Rights Contact</h1>
    <p class="page-intro">
      Send factual corrections, broken links, and rights concerns through the public issue tracker. Security reports use the address in our security.txt file.
    </p>
  </header>

  <section class="section-tight shell">
    <div class="panel">
      <h2>What To Include</h2>
      <ul>
        <li>The Leonida Ledger page URL.</li>
        <li>The exact sentence, link, or image that needs attention.</li>
        <li>An official source URL when reporting a factual correction.</li>
        <li>For security reports, use the contact details in <a href="/.well-known/security.txt">security.txt</a>.</li>
      </ul>
      <p><a class="button secondary" href="https://github.com/PandG19991/gta6-guide-wiki/issues" target="_blank" rel="nofollow noopener">Open the issue tracker</a></p>
    </div>
  </section>
</BaseLayout>

