{
  "name": "leonida-ledger",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "astro check && astro build",
    "check:metadata": "node scripts/check-metadata.mjs",
    "check:indexability": "node scripts/check-indexability.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:content": "node scripts/check-content-quality.mjs",
    "check:media": "node scripts/check-media.mjs",
    "check:live-seo": "node scripts/check-live-seo.mjs",
    "preview": "astro preview --host 127.0.0.1",
    "deploy": "npm run build && npm run check:media && npm run check:metadata && npm run check:indexability && npm run check:links && npm run check:content && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "astro": "^7.0.6",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.3",
    "wrangler": "^4.93.0"
  }
}
